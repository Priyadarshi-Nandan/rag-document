import os
import io
import re
import pdfplumber
import requests
from fastapi import FastAPI, UploadFile, File, HTTPException
from fastapi.staticfiles import StaticFiles
from fastapi.responses import FileResponse
from pathlib import Path
from pydantic import BaseModel

app = FastAPI()

PROJECT_ROOT = Path(__file__).parent.parent
UPLOAD_DIR = PROJECT_ROOT / "uploads"
UPLOAD_DIR.mkdir(exist_ok=True)

FRONTEND_DIR = PROJECT_ROOT / "frontend"
app.mount("/static", StaticFiles(directory=str(FRONTEND_DIR)), name="static")

document_chunks = []
openrouter_api_key = None


class Question(BaseModel):
    question: str


class APIKey(BaseModel):
    api_key: str


def extract_text_from_pdf(file_content: bytes) -> str:
    text = ""
    with pdfplumber.open(io.BytesIO(file_content)) as pdf:
        for page in pdf.pages:
            page_text = page.extract_text()
            if page_text:
                text += page_text + "\n"
    return text


def extract_text_from_txt(file_content: bytes) -> str:
    return file_content.decode("utf-8")


def split_text_into_chunks(text: str, chunk_size: int = 500) -> list:
    words = text.split()
    chunks = []
    for i in range(0, len(words), chunk_size):
        chunk_text = " ".join(words[i:i + chunk_size])
        chunks.append({
            "chunk_id": len(chunks) + 1,
            "text": chunk_text
        })
    return chunks


def find_relevant_chunks(question: str, top_k: int = 5) -> list:
    if not document_chunks:
        return []

    synonyms = {
        "holiday": ["vacation", "break", "term break", "winter vacation"],
        "holidays": ["vacation", "break", "term break", "winter vacation"],
        "exam": ["test", "examination", "mtt", "ete"],
        "classes": ["commencement", "start"]
    }

    question_words = set(re.findall(r"\b\w+\b", question.lower()))

    expanded_words = set()

    for word in question_words:
        expanded_words.add(word)

        if word in synonyms:
            for synonym in synonyms[word]:
                expanded_words.update(synonym.split())

    question_words = expanded_words

    chunk_scores = []

    for chunk in document_chunks:
        chunk_words = set(re.findall(r"\b\w+\b", chunk["text"].lower()))
        overlap = len(question_words & chunk_words)
        chunk_scores.append((overlap, chunk["text"]))

    chunk_scores.sort(reverse=True, key=lambda x: x[0])

    relevant_chunks = [text for _, text in chunk_scores[:top_k]]

    print("QUESTION:", question)
    print("Selected chunks:", relevant_chunks)

    return relevant_chunks


def call_openrouter_llm(question: str) -> str:
    if not openrouter_api_key:
        return "Please add your OpenRouter API key first."
    
    relevant_chunks = find_relevant_chunks(question)
    
    if relevant_chunks:
        user_message = f"Context:\n{chr(10).join(relevant_chunks)}\n\nQuestion:\n{question}"
    else:
        user_message = question
    
    headers = {
        "Authorization": f"Bearer {openrouter_api_key}",
        "Content-Type": "application/json"
    }
    
    system_prompt = """You are a document assistant.

You must answer ONLY using the provided document context.

Rules:

1. If the information is not in the document, say:
   "The document does not contain this information."

2. Format answers clearly for readability.

3. If the answer contains multiple items, dates, or events:
   present them as bullet points.

4. If the answer is an explanation:
   provide a short paragraph.

5. Always keep the answer concise and easy to read.

6. When listing dates or events, format like this:

• Event Name
Date

Example:

• Commencement of Classes
August 11, 2025

• Mid Term Test
October 10 – October 16, 2025

7. Do not invent information outside the provided context.

The context will be provided before the question."""
    
    data = {
        "model": "openai/gpt-3.5-turbo",
        "messages": [
            {"role": "system", "content": system_prompt},
            {"role": "user", "content": user_message}
        ]
    }
    
    response = requests.post(
        "https://openrouter.ai/api/v1/chat/completions",
        headers=headers,
        json=data
    )
    
    result = response.json()
    return result["choices"][0]["message"]["content"]


@app.get("/")
async def root():
    return FileResponse(str(FRONTEND_DIR / "index.html"))


@app.post("/set-api-key")
async def set_api_key(key: APIKey):
    global openrouter_api_key
    openrouter_api_key = key.api_key
    return {"status": "API key stored"}


@app.post("/upload")
async def upload_file(file: UploadFile = File(...)):
    global document_chunks

    allowed_extensions = {".pdf", ".txt"}
    file_ext = os.path.splitext(file.filename)[1].lower()
    
    if file_ext not in allowed_extensions:
        raise HTTPException(
            status_code=400,
            detail="Only PDF and TXT files are allowed"
        )
    
    file_path = UPLOAD_DIR / file.filename
    content = await file.read()
    file_path.write_bytes(content)
    
    if file_ext == ".pdf":
        text = extract_text_from_pdf(content)
    else:
        text = extract_text_from_txt(content)
    
    document_chunks = split_text_into_chunks(text)
    print(f"Document processed. Created {len(document_chunks)} chunks.")
    
    return {"message": f"File '{file.filename}' uploaded successfully"}


@app.post("/ask")
async def ask_question(question: Question):
    answer = call_openrouter_llm(question.question)
    return {"answer": answer}
